{
    "name": "phplrt/parser",
    "type": "library",
    "description": "The phplrt parser library",
    "license": "MIT",
    "keywords": ["parser", "llk", "ll1", "lr", "slr", "language", "php"],
    "homepage": "https://github.com/phplrt",
    "support": {
        "issues": "https://github.com/phplrt/phplrt/issues",
        "source": "https://github.com/phplrt/parser"
    },
    "authors": [
        {
            "name": "Kirill Nesmeyanov",
            "email": "nesk@xakep.ru"
        }
    ],
    "require": {
        "php": "^8.4",
        "ext-spl": "*",
        "ext-pcre": "*",
        "ext-json": "*",
        "phplrt/source": "^4.0",
        "phplrt/lexer": "^4.0",
        "phplrt/parser-contracts": "^4.0"
    },
    "autoload": {
        "psr-4": {
            "Phplrt\\Parser\\": "src"
        }
    },
    "require-dev": {
        "phpunit/phpunit": "^12.5|^13.0",
        "phpstan/phpstan": "^2.1.38",
        "phpstan/phpstan-strict-rules": "^2.0"
    },
    "autoload-dev": {
        "psr-4": {
            "Phplrt\\Parser\\Tests\\": "tests"
        }
    },
    "provide": {
        "phplrt/parser-contracts-implementation": "^4.0"
    },
    "extra": {
        "branch-alias": {
            "dev-master": "4.x-dev",
            "dev-main": "4.x-dev"
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
